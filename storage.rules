rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 1. Product Models: Everyone can read, only authenticated users can trigger migration/upload
    match /product_models/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. User Profiles: Everyone can see photos, but only the owner can upload/change their own
    match /user_profiles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. Chat Attachments: Only the sender or receiver should access these
    match /lanica_chats/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 4. Bug Reports: Only authenticated users can upload
    match /bug_reports/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Global fallback (Safety)
    match /{allPaths=**} {
      allow read, write: if request.time < timestamp.date(2026, 6, 1);
    }
  }
}
