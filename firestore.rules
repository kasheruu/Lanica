rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. User Profile Rules
    // This allows users to read and write ONLY their own data.
    // Prevents other users from seeing your personal info.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. General Store Rules
    // Public can read products, but only authenticated users can write.
    // This matches the current app: storefront uses public reads, admin uses Firebase Auth.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}